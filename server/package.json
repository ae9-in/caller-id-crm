{
  "name": "callcrm-server",
  "version": "1.0.0",
  "description": "Call Intelligence CRM - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:setup": "node database/setup.js",
    "db:clear": "node database/clear-demo-data.js",
    "db:init": "node -e \"const {pool} = require('./src/config/database'); const fs = require('fs'); pool.query(fs.readFileSync('./database/schema.sql','utf8')).then(()=>console.log('Schema applied')).catch(console.error).finally(()=>pool.end())\"",
    "db:seed": "node -e \"const {pool} = require('./src/config/database'); const fs = require('fs'); pool.query(fs.readFileSync('./database/seed.sql','utf8')).then(()=>console.log('Seed data applied')).catch(console.error).finally(()=>pool.end())\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.450.0",
    "@aws-sdk/s3-request-presigner": "^3.450.0",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^4.4.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "music-metadata": "^11.13.0",
    "nodemailer": "^6.9.7",
    "openai": "^4.20.1",
    "p-limit": "2.3.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
